# MinerU DataAgent — Environment Variables Template
# Copy this file to .env and fill in your API keys.

# =============================================================================
# LLM API Keys (for task planning and quality verification)
# =============================================================================

# OpenAI / OpenRouter / DeepSeek / Compatible API
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude (alternative planner/verifier)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# =============================================================================
# MinerU Cloud API (optional — auto-fallback to local models when empty)
# =============================================================================

# MinerU Precise API Token (from https://mineru.net)
# Provides high-accuracy parsing up to 200 pages / 200 MB per file.
MINERU_API_TOKEN=your-mineru-token-here

# =============================================================================
# Processing Configuration (optional overrides)
# =============================================================================

# MINERU_API_MODE=auto
# ANTHROPIC_API_KEY=sk-ant-xxx
